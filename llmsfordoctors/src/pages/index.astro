---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Sidebar from '../components/Sidebar.astro';
import NewsSection from '../components/NewsSection.astro';
let newsData: any[] = [];
try {
  newsData = (await import('../data/news.json')).default;
} catch {
  // news.json may not exist on fresh clones; degrade gracefully
}
---

<BaseLayout
  title="LLMs for Doctors — AI Workflows for Clinicians"
  description="Practical AI workflows, tools, and templates for clinicians. Evidence-based, privacy-aware, specialty-specific."
>
  <Hero />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="flex flex-wrap justify-center gap-3">
      {[
        { href: '/trials',    label: 'Trials' },
        { href: '/workflows', label: 'Workflows' },
        { href: '/guides',    label: 'Guides' },
        { href: '/tools',     label: 'Tools' },
        { href: '/templates', label: 'Templates' },
      ].map(({ href, label }) => (
        <a
          href={href}
          class="px-5 py-2.5 rounded-full text-sm font-medium bg-amber-50 dark:bg-amber-900/30 text-amber-900 dark:text-amber-100 border border-amber-200 dark:border-amber-700 hover:bg-amber-100 dark:hover:bg-amber-800/40 hover:border-amber-300 dark:hover:border-amber-600 transition-colors"
        >
          {label}
        </a>
      ))}
    </div>
  </div>

  <!-- News Section -->
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <NewsSection items={newsData} />
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-clinical-900 rounded-lg p-10 text-center">
      <h2 class="font-heading text-2xl font-semibold text-clinical-50 mb-3">Join the Community</h2>
      <p class="text-clinical-300 mb-6">Connect with verified physicians using AI in clinical practice.</p>
      <a
        href="https://auth.llmsfordoctors.com/register"
        class="inline-block px-6 py-3 bg-clinical-600 hover:bg-clinical-500 text-white text-sm font-medium rounded-md transition-colors"
      >
        Join Now &mdash; Free for Physicians
      </a>
    </div>
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <div class="bg-blue-50 dark:bg-blue-900/20 border border-blue-200 dark:border-blue-800 rounded-lg p-10 text-center">
      <h2 class="font-heading text-2xl font-semibold text-clinical-900 dark:text-clinical-50 mb-3">Support This Project</h2>
      <p class="text-clinical-600 dark:text-clinical-300 mb-6">LLMs for Doctors is free, ad-free, and independent. Your donation helps keep it that way.</p>
      <a
        href="/donate"
        class="inline-block px-6 py-3 bg-blue-600 hover:bg-blue-700 text-white text-sm font-medium rounded-md transition-colors"
      >
        Donate
      </a>
    </div>
  </div>
</BaseLayout>
