---
import { getCollection } from 'astro:content';
import ContentLayout from '../../layouts/ContentLayout.astro';

export async function getStaticPaths() {
  const entries = await getCollection('templates');
  return entries.map((e) => ({ params: { slug: e.id }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();

// Build related items — link to parent workflow if set
const relatedItems: { title: string; href: string; type: 'workflow' | 'guide' | 'tool' | 'template' | 'trial' }[] = [];

if (entry.data.workflow) {
  const { getCollection } = await import('astro:content');
  const workflows = await getCollection('workflows');
  const parentWorkflow = workflows.find((wf) => wf.id === entry.data.workflow);
  if (parentWorkflow) {
    relatedItems.push({
      title: parentWorkflow.data.title,
      href: `/workflows/${parentWorkflow.id}`,
      type: 'workflow',
    });
  }
}

const categoryLabels: Record<string, string> = {
  'note-writing': 'Note Writing',
  'clinical-reasoning': 'Clinical Reasoning',
  'patient-education': 'Patient Education',
  'literature-review': 'Literature Review',
  'admin-billing': 'Admin & Billing',
  'board-prep': 'Board Prep',
};
---

<ContentLayout
  title={entry.data.title}
  lastUpdated={entry.data.lastUpdated}
  tags={entry.data.tags}
  breadcrumbs={[
    { label: 'Home', href: '/' },
    { label: 'Templates', href: '/templates' },
    { label: categoryLabels[entry.data.category] ?? entry.data.category },
    { label: entry.data.title },
  ]}
  relatedItems={relatedItems}
>
  <Content />
</ContentLayout>
